# =============================================================================
# Laravel Backend – Environment Template
# =============================================================================
# Copy this file to .env and fill in values. Never commit .env or real secrets.
# Run: php artisan key:generate (after copying) to set APP_KEY.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Display name of the application (used in logs, emails, etc.).
APP_NAME="Ecommerce API"

# Environment: local, staging, production. Affects error display and caching.
APP_ENV=local

# Encryption key for cookies, sessions, etc. Leave empty; generate with:
#   php artisan key:generate
APP_KEY=

# Set to true only in local/staging. Never true in production (security risk).
APP_DEBUG=true

# Canonical URL of the API (used for links, CORS, and asset URLs).
APP_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database (Docker)
# -----------------------------------------------------------------------------
# These values match the MySQL service in docker-compose.yml. Use DB_HOST=mysql
# when the app runs in Docker on the same network; use 127.0.0.1 when running
# Laravel on the host and MySQL in Docker (port 3306).
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=observability_db
DB_USERNAME=app_user
DB_PASSWORD=app_password

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
# Options: file, database, redis, memcached. Use "file" when no Redis available.
CACHE_STORE=file

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
# Options: file, database, redis, cookie. Use "file" for simple setups.
SESSION_DRIVER=file
# Session lifetime in minutes.
SESSION_LIFETIME=120
# Set to true if you want session payloads encrypted (requires APP_KEY).
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Queue
# -----------------------------------------------------------------------------
# Use "sync" for development (jobs run inline). Use "database" or "redis" for async.
QUEUE_CONNECTION=sync

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Optional: Mail (default: log driver – writes to storage/logs)
# -----------------------------------------------------------------------------
# MAIL_MAILER=log
# MAIL_FROM_ADDRESS="noreply@example.com"
# MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Optional: Redis (if using redis for cache, session, or queue)
# -----------------------------------------------------------------------------
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
